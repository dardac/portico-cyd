# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Solo servidor (nunca exponer en el cliente)
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Supabase → Project Settings → Database → Connection string
# Usa la URI del **Session pooler** (host aws-0-*.pooler.supabase.com)
# NO uses db.*.supabase.co (conexión directa, suele fallar desde local)
# Si la contraseña tiene símbolos, codifícalos: * → %2A, @ → %40
DATABASE_URL=postgresql://postgres.tu-ref:tu-password@aws-0-tu-region.pooler.supabase.com:5432/postgres

# Secreto para sesiones (mínimo 32 caracteres)
AUTH_SECRET=genera-un-secreto-largo-y-aleatorio-de-al-menos-32-caracteres
